# RouterOS CHR via Vagrant/VirtualBox
# Usa box local e 2 NICs host-only: WAN interna (vboxnet1) e LAN (vboxnet0)

Vagrant.configure('2') do |config|
  config.vm.box = 'local/mikrotik-chr'

  # O CHR não tem usuário "vagrant" nem SSH inicial. Evite tentar SSH.
  config.vm.boot_timeout = 60
  # Desabilita forward padrão do SSH criado pelo Vagrant
  config.vm.network 'forwarded_port', guest: 22, host: 2222, id: 'ssh', disabled: true
  # Evita pasta /vagrant
  config.vm.synced_folder '.', '/vagrant', disabled: true
  # Evita detecção/capabilities do guest
  config.vm.guest = :unknown

  # Opções de rede via env:
  # - BRIDGE_IFACE: se definido, NIC1 vira bridged nessa iface (ex.: enp35s0)
  # - WAN_IF: quando não houver BRIDGE_IFACE, usa host-only (default: vboxnet1)
  # - LAN_IF: NIC2 host-only (default: vboxnet0)
  BRIDGE_IFACE    = ENV['BRIDGE_IFACE']
  WAN_HOSTONLY_IF = ENV.fetch('WAN_IF', 'vboxnet1')   # WAN interna (host-only)
  LAN_HOSTONLY_IF = ENV.fetch('LAN_IF', 'vboxnet0')   # LAN (host-only)
  PF_HOST_IP      = ENV.fetch('PF_HOST_IP', '0.0.0.0') # IP do host para bind do port-forward Winbox

  # Opções de console VRDE (RDP) para configurar o CHR pela console
  VRDE_ADDRESS = ENV.fetch('VRDE_ADDRESS', '0.0.0.0')
  VRDE_PORT    = ENV.fetch('VRDE_PORT', '5000')

  # Não usamos DSL de network do Vagrant para evitar NAT implícito; ajustamos direto no VirtualBox
  config.vm.provider 'virtualbox' do |vb|
    vb.name   = 'chr-edge'
    vb.cpus   = 1
    vb.memory = 512

    # Habilita console VRDE (RDP) com senha
    vb.customize ['modifyvm', :id, '--vrde', 'on']
    vb.customize ['modifyvm', :id, '--vrdeaddress', VRDE_ADDRESS]
    vb.customize ['modifyvm', :id, '--vrdeport', VRDE_PORT]
    vb.customize ['modifyvm', :id, '--vrdeauthtype', 'external']
    vb.customize ['modifyvm', :id, '--vrdeproperty', 'VNCPassword=vagrant']

    # NIC1: bridged (se BRIDGE_IFACE definido) ou host-only (WAN interna)
    if BRIDGE_IFACE && !BRIDGE_IFACE.empty?
      vb.customize ['modifyvm', :id, '--nic1', 'bridged']
      vb.customize ['modifyvm', :id, '--bridgeadapter1', BRIDGE_IFACE]
    else
      vb.customize ['modifyvm', :id, '--nic1', 'hostonly']
      vb.customize ['modifyvm', :id, '--hostonlyadapter1', WAN_HOSTONLY_IF]
    end
    vb.customize ['modifyvm', :id, '--nictype1', '82540EM']
    vb.customize ['modifyvm', :id, '--nicpromisc1', 'allow-all']

    # NIC2: host-only (LAN)
    vb.customize ['modifyvm', :id, '--nic2', 'hostonly']
    vb.customize ['modifyvm', :id, '--hostonlyadapter2', LAN_HOSTONLY_IF]
    vb.customize ['modifyvm', :id, '--nictype2', '82540EM']
    vb.customize ['modifyvm', :id, '--nicpromisc2', 'allow-all']

    # NIC3: NAT para port-forward do Winbox (8291) do host -> guest
    vb.customize ['modifyvm', :id, '--nic3', 'nat']
    vb.customize ['modifyvm', :id, '--nictype3', '82540EM']
    vb.customize ['modifyvm', :id, '--natpf3', "winbox,tcp,#{PF_HOST_IP},8291,,8291"]
  end

  # Nenhum provisionamento automático (usar bootstrap.rsc manualmente)
end
